# ===========================================
# 个人博客系统 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ==================== 数据库配置 ====================
POSTGRES_USER=admin
POSTGRES_PASSWORD=Why123456
POSTGRES_DB=blog
POSTGRES_PORT=5432

# ==================== 服务端口 ====================
BACKEND_PORT=3000
FRONTEND_PORT=3002
ADMIN_PORT=3001

# ==================== 环境模式 ====================
NODE_ENV=production
BACKEND_HOST=localhost

# ==================== 阿里云 OSS (可选) ====================
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET=your_bucket_name
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# USE_OSS=false
